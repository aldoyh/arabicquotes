<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مقولات من ما قيل من خيرة العرب</title>
    <meta name="description" content="مقولات من خيرة العرب - مجموعة من الاقتباسات الجميلة من أدب وحكمة العرب">
    <meta property="og:title" content="مقولات من خيرة العرب">
    <meta property="og:description" content="مقولات من خيرة العرب - مجموعة من الاقتباسات الجميلة من أدب وحكمة العرب">
    <meta property="og:image" content="assets/arabicquotes-header.jpg">
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Aref+Ruqaa:wght@400;700&family=Noto+Kufi+Arabic:wght@400;500;600;700&family=Noto+Naskh+Arabic:wght@400;500;600;700&family=Reem+Kufi:wght@400;500;600;700&family=Scheherazade+New:wght@400;700&display=swap" rel="stylesheet">
    <script type="text/javascript">
        window.tailwind.config = {
            darkMode: ['class'],
            theme: {
                extend: {
                    fontFamily: {
                        'kufi': ['Noto Kufi Arabic', 'sans-serif'],
                        'naskh': ['Noto Naskh Arabic', 'serif'],
                        'amiri': ['Amiri', 'serif'],
                        'ruqaa': ['Aref Ruqaa', 'serif'],
                        'reem': ['Reem Kufi', 'sans-serif'],
                        'scheherazade': ['Scheherazade New', 'serif'],
                    },
                    animation: {
                        'fade-in': 'fade-in 0.8s ease-in-out',
                        'slide-up': 'slide-up 0.6s ease-out',
                        'float': 'float 6s ease-in-out infinite',
                        'glow': 'glow 2s ease-in-out infinite alternate',
                        'ornament-spin': 'ornament-spin 20s linear infinite',
                    },
                    keyframes: {
                        'fade-in': {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        'slide-up': {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        },
                        'float': {
                            '0%, 100%': { transform: 'translateY(0px)' },
                            '50%': { transform: 'translateY(-10px)' },
                        },
                        'glow': {
                            '0%': { boxShadow: '0 0 20px rgba(217, 119, 6, 0.3)' },
                            '100%': { boxShadow: '0 0 30px rgba(217, 119, 6, 0.6)' },
                        },
                        'ornament-spin': {
                            '0%': { transform: 'rotate(0deg)' },
                            '100%': { transform: 'rotate(360deg)' },
                        },
                    },
                }
            }
        }
    </script>
    <style>
        body {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            min-height: 100vh;
            position: relative;
        }
        
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                radial-gradient(circle at 20% 50%, rgba(251, 191, 36, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(217, 119, 6, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 40% 20%, rgba(245, 158, 11, 0.08) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }
        
        .dark body {
            background: linear-gradient(135deg, #1a1410 0%, #0f0a08 100%);
        }
        
        .dark body::before {
            background-image: 
                radial-gradient(circle at 20% 50%, rgba(217, 119, 6, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(245, 158, 11, 0.05) 0%, transparent 50%);
        }
        
        .ornament-pattern {
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0l5 10-5 10-5-10zM0 30l10-5 10 5-10 5zM60 30l-10-5-10 5 10 5zM30 60l-5-10 5-10 5 10z' fill='%23f59e0b' fill-opacity='0.03'/%3E%3C/svg%3E");
        }
        
        .dark .ornament-pattern {
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0l5 10-5 10-5-10zM0 30l10-5 10 5-10 5zM60 30l-10-5-10 5 10 5zM30 60l-5-10 5-10 5 10z' fill='%23f59e0b' fill-opacity='0.02'/%3E%3C/svg%3E");
        }
        
        .quote-text {
            font-family: 'Scheherazade New', 'Amiri', serif;
            line-height: 2.2;
            letter-spacing: 0.02em;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.08);
            position: relative;
            z-index: 1;
        }
        
        .author-text {
            font-family: 'Aref Ruqaa', serif;
            font-size: 1.35rem;
        }
        
        .page-title {
            font-family: 'Reem Kufi', sans-serif;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        }
        
        .quote-card {
            background: linear-gradient(145deg, #fffbeb 0%, #fef3c7 50%, #fde68a 100%);
            box-shadow: 
                0 20px 60px -15px rgba(120, 80, 40, 0.3),
                0 10px 30px -10px rgba(180, 140, 60, 0.2),
                inset 0 1px 0 rgba(255, 255, 255, 0.8);
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border: 2px solid rgba(217, 119, 6, 0.15);
        }
        
        .quote-card::before {
            content: '❝';
            position: absolute;
            top: -20px;
            right: 30px;
            font-size: 200px;
            line-height: 1;
            font-family: 'Scheherazade New', serif;
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            opacity: 0.08;
            z-index: 0;
        }
        
        .quote-card::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100px;
            height: 100px;
            background: radial-gradient(circle, rgba(217, 119, 6, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            animation: float 6s ease-in-out infinite;
        }
        
        .quote-card:hover {
            transform: translateY(-5px) scale(1.01);
            box-shadow: 
                0 25px 70px -15px rgba(100, 70, 40, 0.35),
                0 15px 40px -10px rgba(180, 140, 60, 0.25),
                inset 0 1px 0 rgba(255, 255, 255, 0.9),
                0 0 0 1px rgba(217, 119, 6, 0.2);
        }
        
        .dark .quote-card {
            background: linear-gradient(145deg, #2d1f13 0%, #1f1610 50%, #12100c 100%);
            box-shadow: 
                0 20px 60px -15px rgba(0, 0, 0, 0.6),
                0 10px 30px -10px rgba(217, 119, 6, 0.15),
                inset 0 1px 0 rgba(217, 119, 6, 0.1);
            border: 2px solid rgba(217, 119, 6, 0.25);
        }
        
        .dark .quote-card::before {
            opacity: 0.06;
        }
        
        .dark .quote-card::after {
            background: radial-gradient(circle, rgba(217, 119, 6, 0.15) 0%, transparent 70%);
        }
        
        .dark .quote-card:hover {
            box-shadow: 
                0 25px 70px -15px rgba(0, 0, 0, 0.7),
                0 15px 40px -10px rgba(217, 119, 6, 0.2),
                inset 0 1px 0 rgba(217, 119, 6, 0.15),
                0 0 0 1px rgba(217, 119, 6, 0.3);
        }
        
        .ornament-corner {
            position: absolute;
            width: 60px;
            height: 60px;
            opacity: 0.15;
        }
        
        .ornament-top-right {
            top: 10px;
            left: 10px;
            background: url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M50 10 L60 30 L80 25 L65 45 L85 55 L65 60 L75 80 L50 65 L25 80 L35 60 L15 55 L35 45 L20 25 L40 30 Z' fill='%23d97706' /%3E%3C/svg%3E") no-repeat center;
        }
        
        .ornament-bottom-left {
            bottom: 10px;
            right: 10px;
            background: url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M50 10 L60 30 L80 25 L65 45 L85 55 L65 60 L75 80 L50 65 L25 80 L35 60 L15 55 L35 45 L20 25 L40 30 Z' fill='%23d97706' /%3E%3C/svg%3E") no-repeat center;
            transform: rotate(180deg);
        }
        
        .header-ornament {
            position: absolute;
            width: 150px;
            height: 150px;
            opacity: 0.1;
            animation: ornament-spin 20s linear infinite;
        }
        
        .border-ornament {
            background: linear-gradient(90deg, 
                transparent 0%, 
                rgba(217, 119, 6, 0.3) 20%, 
                rgba(217, 119, 6, 0.5) 50%, 
                rgba(217, 119, 6, 0.3) 80%, 
                transparent 100%);
            height: 3px;
            margin: 1rem auto;
            max-width: 200px;
        }
    </style>
</head>
<body class="ornament-pattern transition-colors duration-500">
    <div class="container mx-auto p-4 md:p-6 xl:p-8 max-w-6xl relative z-10">
        <!-- Theme toggle button with improved styling -->
        <div class="flex justify-end mb-6">
            <button id="theme-toggle" class="group p-3 rounded-full bg-gradient-to-br from-amber-200 to-amber-300 dark:from-amber-900/50 dark:to-amber-800/50 focus:outline-none focus:ring-4 focus:ring-amber-400/50 transition-all duration-300 hover:scale-110 hover:rotate-12 shadow-lg hover:shadow-2xl">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-800 dark:text-amber-300 hidden dark:block transition-transform group-hover:rotate-180 duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-900 dark:hidden transition-transform group-hover:-rotate-12 duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                </svg>
            </button>
        </div>
        
        <!-- Main content with enhanced design -->
        <div class="bg-white/95 dark:bg-gray-900/95 backdrop-blur-md rounded-3xl shadow-2xl overflow-hidden border-2 border-amber-200/60 dark:border-amber-800/40 animate-fade-in relative">
            <!-- Decorative ornaments -->
            <div class="ornament-corner ornament-top-right"></div>
            <div class="ornament-corner ornament-bottom-left"></div>
            
            <!-- Header with enhanced gradient and ornaments -->
            <header class="relative overflow-hidden py-12 md:py-16">
                <div class="absolute inset-0 bg-gradient-to-br from-amber-600 via-amber-700 to-amber-800 dark:from-amber-900 dark:via-amber-950 dark:to-gray-900"></div>
                
                <!-- Decorative pattern overlay -->
                <div class="absolute inset-0 opacity-10">
                    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'100\' height=\'100\' viewBox=\'0 0 100 100\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M50 0 L55 15 L70 20 L55 25 L50 40 L45 25 L30 20 L45 15 Z\' fill=\'white\' fill-opacity=\'0.3\'/%3E%3C/svg%3E'); background-size: 100px 100px;"></div>
                </div>
                
                <div class="relative z-10 px-6 md:px-10">
                    <div class="text-center">
                        <!-- Decorative top ornament -->
                        <div class="inline-block mb-4">
                            <svg class="w-20 h-20 mx-auto text-amber-200/40" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" role="presentation">
                                <path d="M50 10 L60 30 L80 25 L65 45 L85 55 L65 60 L75 80 L50 65 L25 80 L35 60 L15 55 L35 45 L20 25 L40 30 Z"/>
                            </svg>
                        </div>
                        
                        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white page-title mb-3 drop-shadow-lg">
                            ما قيل من خيرة العرب
                        </h1>
                        
                        <div class="border-ornament"></div>
                        
                        <p class="text-amber-100 text-base md:text-lg max-w-2xl mx-auto leading-relaxed">
                            مجموعة من أجمل الأقوال المأثورة والحكم العربية
                        </p>
                        
                        <!-- Decorative bottom ornament -->
                        <div class="inline-block mt-4">
                            <svg class="w-16 h-16 mx-auto text-amber-200/30" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" role="presentation">
                                <circle cx="50" cy="50" r="5"/>
                                <circle cx="30" cy="50" r="3"/>
                                <circle cx="70" cy="50" r="3"/>
                                <circle cx="50" cy="30" r="3"/>
                                <circle cx="50" cy="70" r="3"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </header>
            
            <!-- Quote section with enhanced styling -->
            <div class="p-8 md:p-12 lg:p-16 bg-gradient-to-b from-amber-50/50 to-white dark:from-gray-800/50 dark:to-gray-900">
                <div class="max-w-4xl mx-auto">
                    <!-- Section title with ornamental divider -->
                    <div class="text-center mb-10">
                        <h2 class="text-3xl md:text-4xl font-bold text-amber-900 dark:text-amber-200 page-title inline-block relative">
                            <span class="relative z-10">اقتباس اليوم</span>
                            <div class="absolute -bottom-2 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-amber-500 to-transparent opacity-60"></div>
                        </h2>
                    </div>
                    
                    <div id="quote-container">
        <div class="flex flex-col items-center animate-slide-up">
            <div class="w-full quote-card rounded-2xl p-10 md:p-12 mb-8 relative">
                <!-- Quote text with enhanced typography -->
                <div class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-amber-50 mb-8 text-center leading-loose quote-text">
                    من يقتر على نفسه يكدس الثروة لغيره
                </div>
                
                <!-- Decorative divider -->
                <div class="flex items-center justify-center my-6">
                    <div class="h-px w-12 bg-gradient-to-r from-transparent to-amber-400"></div>
                    <svg class="w-8 h-8 mx-4 text-amber-600 dark:text-amber-400" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" role="presentation">
                        <circle cx="50" cy="50" r="6"/>
                        <circle cx="30" cy="50" r="4"/>
                        <circle cx="70" cy="50" r="4"/>
                    </svg>
                    <div class="h-px w-12 bg-gradient-to-l from-transparent to-amber-400"></div>
                </div>
                
                <!-- Author with enhanced styling -->
                <div class="text-2xl md:text-3xl font-bold text-amber-800 dark:text-amber-300 text-center author-text">
                    — البخل
                </div>
            </div>
            
            <!-- Metadata with icons -->
            <div class="text-sm text-gray-600 dark:text-gray-400 flex items-center gap-4 flex-wrap justify-center bg-amber-50/50 dark:bg-gray-800/50 px-6 py-3 rounded-full border border-amber-200/50 dark:border-amber-800/50">
                <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    اليوم: Wednesday 21st of January 2026 - 15:08
                </span>
                <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                    المشاهدات: 0
                </span>
            </div>
        </div></div>
                </div>
            </div>
        </div>
        
        <!-- Enhanced Footer -->
        <footer class="mt-16 pb-8">
            <div class="max-w-5xl mx-auto text-center">
                <!-- Decorative ornament -->
                <div class="mb-6">
                    <svg class="w-16 h-16 mx-auto text-amber-600/40 dark:text-amber-400/40" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" role="presentation">
                        <path d="M50 20 L55 35 L70 40 L55 45 L50 60 L45 45 L30 40 L45 35 Z"/>
                        <circle cx="50" cy="80" r="4"/>
                    </svg>
                </div>
                
                <div class="text-amber-800 dark:text-amber-300 mb-6">
                    <p class="text-lg font-semibold page-title">مقولات من خيرة العرب © <span id="copyright-year">2026</span></p>
                    <p class="text-sm mt-2 text-amber-700 dark:text-amber-400">كنز من الحكمة والأدب العربي الأصيل</p>
                </div>
                
                <div class="flex justify-center gap-6">
                    <a href="https://github.com/aldoyh/arabicquotes" class="group inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-amber-600 to-amber-700 hover:from-amber-700 hover:to-amber-800 dark:from-amber-800 dark:to-amber-900 text-white rounded-full transition-all duration-300 hover:scale-105 hover:shadow-lg" aria-label="GitHub Repository">
                        <svg class="w-5 h-5 transition-transform group-hover:rotate-12" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="font-semibold">GitHub</span>
                    </a>
                </div>
            </div>
        </footer>
    </div>
    
    <script>
        // Theme toggle functionality
        const themeToggle = document.getElementById('theme-toggle');
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
        themeToggle.addEventListener('click', function() {
            document.documentElement.classList.toggle('dark');
            if (document.documentElement.classList.contains('dark')) {
                localStorage.theme = 'dark';
            } else {
                localStorage.theme = 'light';
            }
        });
        
        // Update copyright year dynamically
        document.getElementById('copyright-year').textContent = new Date().getFullYear();
    </script>
</body>
</html>
